<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="calculator.Controller.CalculatorController"
      fx:id="root"
      spacing="10" alignment="CENTER" styleClass="root-box">
    
    <TextField fx:id="display" editable="false" prefHeight="50" prefWidth="280"
               styleClass="display"/>

    <GridPane hgap="10" vgap="10">
        <!-- Row 1 -->
        <Button text="7" onAction="#handleButtonAction" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <Button text="8" onAction="#handleButtonAction" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
        <Button text="9" onAction="#handleButtonAction" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
        <Button text="/" onAction="#handleButtonAction" GridPane.rowIndex="0" GridPane.columnIndex="3"/>
        
        <!-- Row 2 -->
        <Button text="4" onAction="#handleButtonAction" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <Button text="5" onAction="#handleButtonAction" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        <Button text="6" onAction="#handleButtonAction" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
        <Button text="*" onAction="#handleButtonAction" GridPane.rowIndex="1" GridPane.columnIndex="3"/>
        
        <!-- Row 3 -->
        <Button text="1" onAction="#handleButtonAction" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <Button text="2" onAction="#handleButtonAction" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
        <Button text="3" onAction="#handleButtonAction" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
        <Button text="-" onAction="#handleButtonAction" GridPane.rowIndex="2" GridPane.columnIndex="3"/>
        
        <!-- Row 4 -->
        <Button text="0" onAction="#handleButtonAction" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <Button text="C" onAction="#handleButtonAction" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
        <Button text="=" onAction="#handleButtonAction" GridPane.rowIndex="3" GridPane.columnIndex="2"/>
        <Button text="+" onAction="#handleButtonAction" GridPane.rowIndex="3" GridPane.columnIndex="3"/>
    </GridPane>
</VBox>
