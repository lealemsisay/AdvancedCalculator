<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="root" alignment="CENTER" spacing="10" styleClass="root-box" stylesheets="@../styles/styles.css" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/8" fx:controller="calculator.Controller.CalculatorController">
   <children>
       
       <TextField fx:id="display" editable="false" prefHeight="50" prefWidth="280" styleClass="display" stylesheets="@../styles/styles.css" />
   
       <GridPane hgap="10" stylesheets="@../styles/styles.css" vgap="10">
      <children>
              <!-- Row 1 -->
              <Button onAction="#handleButtonAction" text="7" GridPane.columnIndex="0" GridPane.rowIndex="0" />
              <Button onAction="#handleButtonAction" text="8" GridPane.columnIndex="1" GridPane.rowIndex="0" />
              <Button onAction="#handleButtonAction" text="9" GridPane.columnIndex="2" GridPane.rowIndex="0" />
              <Button onAction="#handleButtonAction" text="/" GridPane.columnIndex="3" GridPane.rowIndex="0" />
              
              <!-- Row 2 -->
              <Button onAction="#handleButtonAction" text="4" GridPane.columnIndex="0" GridPane.rowIndex="1" />
              <Button onAction="#handleButtonAction" text="5" GridPane.columnIndex="1" GridPane.rowIndex="1" />
              <Button onAction="#handleButtonAction" text="6" GridPane.columnIndex="2" GridPane.rowIndex="1" />
              <Button onAction="#handleButtonAction" text="*" GridPane.columnIndex="3" GridPane.rowIndex="1" />
              
              <!-- Row 3 -->
              <Button onAction="#handleButtonAction" text="1" GridPane.columnIndex="0" GridPane.rowIndex="2" />
              <Button onAction="#handleButtonAction" text="2" GridPane.columnIndex="1" GridPane.rowIndex="2" />
              <Button onAction="#handleButtonAction" text="3" GridPane.columnIndex="2" GridPane.rowIndex="2" />
              <Button onAction="#handleButtonAction" text="-" GridPane.columnIndex="3" GridPane.rowIndex="2" />
              
              <!-- Row 4 -->
              <Button onAction="#handleButtonAction" text="0" GridPane.columnIndex="0" GridPane.rowIndex="3" />
              <Button onAction="#handleButtonAction" text="C" GridPane.columnIndex="1" GridPane.rowIndex="3" />
              <Button onAction="#handleButtonAction" text="=" GridPane.columnIndex="2" GridPane.rowIndex="3" />
              <Button onAction="#handleButtonAction" text="+" GridPane.columnIndex="3" GridPane.rowIndex="3" />
      </children>
         <columnConstraints>
            <ColumnConstraints />
            <ColumnConstraints />
            <ColumnConstraints />
            <ColumnConstraints />
         </columnConstraints>
         <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
         </rowConstraints>
       </GridPane>
   </children>
</VBox>
